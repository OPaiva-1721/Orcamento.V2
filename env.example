# =====================================================
# Banco de Dados (Postgres) — NUNCA commitar valores reais
# =====================================================
POSTGRES_DB=orcamento
POSTGRES_USER=orcamento
POSTGRES_PASSWORD=CHANGE_ME_STRONG_RANDOM_VALUE

# String de conexão consumida pelos apps (gerada a partir das vars acima ou
# apontada para um banco gerenciado em produção)
DATABASE_URL="postgresql://orcamento:CHANGE_ME_STRONG_RANDOM_VALUE@localhost:5432/orcamento"

# =====================================================
# Email (SMTP) — usar App Password, nunca senha real
# =====================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# =====================================================
# URLs / CORS
# =====================================================
FRONTEND_URL=http://localhost:5173

# =====================================================
# TLS / Domínio (somente produção; usado por docker-compose.prod.yml e nginx)
# =====================================================
DOMAIN=
SSL_EMAIL=

# =====================================================
# Firebase Admin SDK (backend)
# =====================================================
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
