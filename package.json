{
  "name": "orcamento-monorepo",
  "version": "0.1.1",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "db:push": "pnpm --filter @orcamento/db db:push",
    "db:generate": "pnpm --filter @orcamento/db db:generate",
    "db:migrate": "pnpm --filter @orcamento/db db:migrate",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f api"
  },
  "devDependencies": {
    "turbo": "^2.3.3"
  }
}
